# Partial SSH config — included from ~/.ssh/config via setup.sh.
# Host-specific config (hostname, user, identity file) lives in ~/.ssh/config directly.

Host *
  # Reuse existing connections for subsequent SSH calls to the same host,
  # avoiding re-authentication. Socket persists for 10 minutes after last use.
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m
